[
  {
    "context": "Editor",
    "bindings": {
      "jj": "editor::Cancel",
      "ctrl-[": "editor::Cancel",
      "ctrl-d": "editor::HalfPageDown",
      "ctrl-u": "editor::HalfPageUp"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "shift-\\": "pane::SplitRight",
      "-": "pane::SplitDown"
    }
  },
  {
    "bindings": {
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-h": "editor::DeleteToBeginningOfLine",
      "ctrl-k": "editor::DeleteToEndOfLine",
      "alt-backspace": "editor::DeleteToPreviousWordStart",
      "ctrl-s": "workspace::Save",
      "ctrl-p": "file_finder::Toggle",
      "ctrl-shift-p": "command_palette::Toggle"
    }
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "space": "file_finder::Toggle"
    }
  },
  {
    "context": "Workspace && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      "space e": "project_panel::ToggleFocus",
      "ctrl-shift-\\": "terminal_panel::Toggle"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "space e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "space q": "pane::CloseActiveItem"
    }
  },
  {
    "bindings": {
      "ctrl-b h": "workspace::ActivatePaneLeft",
      "ctrl-b j": "workspace::ActivatePaneDown",
      "ctrl-b k": "workspace::ActivatePaneUp",
      "ctrl-b l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-`": "workspace::ToggleBottomDock"
    }
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "space f w": "project_symbols::Toggle"
    }
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "g shift-s": "project_symbols::Toggle"
    }
  }
]