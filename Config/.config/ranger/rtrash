#!/usr/bin/env python3
import os
import shutil
import argparse
import subprocess
import sqlite3
from urllib.parse import unquote
from datetime import datetime

TRASH_DB = os.path.expanduser("~/.local/share/ranger_trash/trash.db")


def init_db():
    os.makedirs(os.path.dirname(TRASH_DB), exist_ok=True)
    conn = sqlite3.connect(TRASH_DB)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS trash (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        original_path TEXT NOT NULL,
        trash_path TEXT NOT NULL,
        file_name TEXT NOT NULL,
        deleted_at TEXT NOT NULL,
        file_size INTEGER,
        is_directory INTEGER
    )''')
    conn.commit()
    conn.close()


def get_size(path):
    """Get size of file or directory"""
    if os.path.isfile(path):
        return os.path.getsize(path)
    elif os.path.isdir(path):
        total = 0
        for dirpath, dirnames, filenames in os.walk(path):
            for f in filenames:
                fp = os.path.join(dirpath, f)
                if os.path.exists(fp):
                    total += os.path.getsize(fp)
        return total
    return 0


def add_to_trash(original_path, trash_path, file_name, is_directory):
    conn = sqlite3.connect(TRASH_DB)
    c = conn.cursor()
    trash_file = os.path.join(trash_path, "files", file_name)
    file_size = get_size(trash_file) if os.path.exists(trash_file) else 0
    c.execute("INSERT INTO trash (original_path, trash_path, file_name, deleted_at, file_size, is_directory) VALUES (?, ?, ?, ?, ?, ?)",
              (original_path, trash_path, file_name, datetime.now().isoformat(), file_size, 1 if is_directory else 0))
    conn.commit()
    conn.close()


def get_all_trash():
    conn = sqlite3.connect(TRASH_DB)
    c = conn.cursor()
    c.execute("SELECT id, original_path, trash_path, file_name, deleted_at, file_size FROM trash ORDER BY deleted_at DESC")
    rows = c.fetchall()
    conn.close()
    return rows


def find_by_filename(filename):
    conn = sqlite3.connect(TRASH_DB)
    c = conn.cursor()
    c.execute("SELECT id, original_path, trash_path, file_name FROM trash WHERE file_name = ?", (filename,))
    rows = c.fetchall()
    conn.close()
    return rows


def remove_from_trash(original_path):
    conn = sqlite3.connect(TRASH_DB)
    c = conn.cursor()
    c.execute("DELETE FROM trash WHERE original_path = ?", (original_path,))
    conn.commit()
    conn.close()


def get_trash_path(original_path, username):
    base = os.path.expanduser("~/.local/share/trash")
    if original_path.startswith("/media") or original_path.startswith("/mnt") or original_path.startswith("/run/media"):
        for prefix in [f"/run/media/{username}", f"/media/{username}", "/mnt"]:
            if original_path.startswith(prefix):
                mount = original_path[len(prefix):].split("/")[1] if len(original_path[len(prefix):].split("/")) > 1 else ""
                base = os.path.join(prefix, mount, ".Trash-1000")
                break
    return base


def get_all_items(username):
    rows = get_all_trash()
    system_items = scan_system_trash(username)
    
    all_items = []
    
    for row in rows:
        trash_path = row[2]
        file_name = row[3]
        src1 = os.path.join(trash_path, "files", file_name)
        src2 = os.path.join(trash_path, file_name)
        if os.path.exists(src1) or os.path.exists(src2):
            size = get_size(src1) if os.path.exists(src1) else get_size(src2) if os.path.exists(src2) else row[5]
            all_items.append({
                "original_path": row[1],
                "trash_path": row[2],
                "file_name": row[3],
                "file_size": size,
                "is_system": False
            })
    
    for item in system_items:
        exists_in_db = any(x["original_path"] == item["original_path"] for x in all_items)
        if not exists_in_db:
            all_items.append(item)
    
    return all_items


def format_size(size):
    """Format size in human readable format"""
    for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
        if size < 1024:
            return f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}PB"


def cmd_list():
    username = subprocess.run(["id", "-nu"], capture_output=True, text=True).stdout.strip()
    all_items = get_all_items(username)
    
    if not all_items:
        print("Trash is empty!")
        return
    
    print("┌" + "─" * 15 + "┬" + "─" * 10 + "┬" + "─" * 40 + "┬" + "─" * 30 + "┐")
    print("│ {:^13} │ {:^8} │ {:^38} │ {:^28} │".format("File Name", "Size", "Original Path", "Trash Location"))
    print("├" + "─" * 15 + "┼" + "─" * 10 + "┼" + "─" * 40 + "┼" + "─" * 30 + "┤")
    
    for item in all_items:
        fname = item['file_name'][:13] if len(item['file_name']) > 13 else item['file_name']
        size = format_size(item.get('file_size', 0)) if 'file_size' in item else "0B"
        opath = item['original_path'][:38] if len(item['original_path']) > 38 else item['original_path']
        tpath = item['trash_path'][:28] if len(item['trash_path']) > 28 else item['trash_path']
        print("│ {:13} │ {:>8} │ {:38} │ {:28} │".format(fname, size, opath, tpath))
    
    print("└" + "─" * 15 + "┴" + "─" * 10 + "┴" + "─" * 40 + "┴" + "─" * 30 + "┘")
    total_size = sum(item.get('file_size', 0) for item in all_items)
    print(f"\nTotal: {len(all_items)} item(s), {format_size(total_size)}")


def scan_system_trash(username):
    items = []
    bases = [f"/run/media/{username}", f"/media/{username}", "/mnt", "/run/media", "/media"]
    
    for base in bases:
        if not os.path.exists(base):
            continue
        try:
            for mount in os.listdir(base):
                trash_path = os.path.join(base, mount, ".Trash-1000")
                if os.path.exists(trash_path):
                    info_dir = os.path.join(trash_path, "info")
                    files_dir = os.path.join(trash_path, "files")
                    if os.path.exists(info_dir) and os.path.exists(files_dir):
                        for f in os.listdir(files_dir):
                            info_file = os.path.join(info_dir, f + ".trashinfo")
                            if os.path.exists(info_file):
                                with open(info_file) as fh:
                                    for line in fh:
                                        if line.startswith("Path="):
                                            orig_path = unquote(line[5:].strip())
                                            if not orig_path.startswith("/"):
                                                orig_path = "/" + orig_path
                                            size = get_size(os.path.join(files_dir, f))
                                            items.append({
                                                "original_path": orig_path,
                                                "trash_path": trash_path,
                                                "file_name": f,
                                                "file_size": size,
                                                "is_system": True
                                            })
                                            break
        except PermissionError:
            pass
    
    return items


def cmd_restore(*files):
    username = subprocess.run(["id", "-nu"], capture_output=True, text=True).stdout.strip()
    all_items = get_all_items(username)
    
    if not all_items:
        print("Trash is empty!")
        return
    
    if not files:
        lines = [f"{item['file_name']} | {item['original_path']} -> {item['trash_path']}" for item in all_items]
        
        fzf = subprocess.Popen(
            ["fzf", "--prompt", "Restore> ", "--multi"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            text=True,
        )
        stdout, _ = fzf.communicate(input="\n".join(lines))
        
        if fzf.returncode != 0 or not stdout.strip():
            return
        
        selected = stdout.strip().split("\n")
        files = [s.split(" | ")[0] for s in selected]
    
    for filename in files:
        src = None
        
        db_results = find_by_filename(filename)
        if db_results:
            trash_id, original_path, trash_path, trash_name = db_results[0]
            test_src = os.path.join(trash_path, "files", trash_name)
            if os.path.exists(test_src):
                src = test_src
            elif os.path.exists(os.path.join(trash_path, trash_name)):
                src = os.path.join(trash_path, trash_name)
        
        if not src:
            for base in [f"/run/media/{username}", f"/media/{username}", "/mnt"]:
                if not os.path.exists(base):
                    continue
                try:
                    for mount in os.listdir(base):
                        trash_path = os.path.join(base, mount, ".Trash-1000")
                        if os.path.exists(trash_path):
                            files_dir = os.path.join(trash_path, "files")
                            if os.path.exists(files_dir):
                                test_src = os.path.join(files_dir, os.path.basename(filename))
                                if os.path.exists(test_src):
                                    src = test_src
                except PermissionError:
                    pass
        
        if not src:
            print(f"Not found: {filename}")
            continue
        
        original_path = os.path.basename(filename)
        
        result = subprocess.run(["mv", src, original_path], capture_output=True, text=True)
        if result.returncode == 0 and os.path.exists(original_path):
            if src.startswith(os.path.expanduser("~/.local/share")):
                remove_from_trash(original_path)
            print(f"Restored: {original_path}")
        else:
            print(f"Failed: {filename}")


def cmd_delete(*files):
    username = subprocess.run(["id", "-nu"], capture_output=True, text=True).stdout.strip()
    all_items = get_all_items(username)
    
    if not all_items:
        print("Trash is empty!")
        return
    
    if not files:
        lines = [f"{item['file_name']} | {item['original_path']} -> {item['trash_path']}" for item in all_items]
        
        fzf = subprocess.Popen(
            ["fzf", "--prompt", "Delete> ", "--multi"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            text=True,
        )
        stdout, _ = fzf.communicate(input="\n".join(lines))
        
        if fzf.returncode != 0 or not stdout.strip():
            return
        
        selected = stdout.strip().split("\n")
        files = [s.split(" | ")[0] for s in selected]
    
    for filename in files:
        src = None
        original_path = None
        
        db_results = find_by_filename(filename)
        if db_results:
            trash_id, original_path, trash_path, trash_name = db_results[0]
            test_src = os.path.join(trash_path, "files", trash_name)
            if os.path.exists(test_src):
                src = test_src
            elif os.path.exists(os.path.join(trash_path, trash_name)):
                src = os.path.join(trash_path, trash_name)
        
        if not src:
            for base in [f"/run/media/{username}", f"/media/{username}", "/mnt"]:
                if not os.path.exists(base):
                    continue
                try:
                    for mount in os.listdir(base):
                        trash_path = os.path.join(base, mount, ".Trash-1000")
                        if os.path.exists(trash_path):
                            files_dir = os.path.join(trash_path, "files")
                            if os.path.exists(files_dir):
                                test_src = os.path.join(files_dir, os.path.basename(filename))
                                if os.path.exists(test_src):
                                    src = test_src
                                    break
                except PermissionError:
                    pass
        
        if not src:
            print(f"Not found: {filename}")
            continue
        
        result = subprocess.run(["rm", "-rf", src], capture_output=True, text=True)
        if result.returncode == 0:
            if original_path:
                remove_from_trash(original_path)
            print(f"Deleted: {os.path.basename(filename)}")
        else:
            print(f"Failed: {filename}")


def cmd_put(*files):
    if not files:
        print("Usage: rtrash put <filename> [<filename>...]")
        return
    
    username = subprocess.run(["id", "-nu"], capture_output=True, text=True).stdout.strip()
    
    for f in files:
        if not os.path.exists(f):
            print(f"Not found: {f}")
            continue
            
        file_name = os.path.basename(f)
        is_dir = os.path.isdir(f)
        
        trash_path = get_trash_path(os.path.abspath(f), username)
        trash_files = os.path.join(trash_path, "files")
        
        unique_name = file_name
        counter = 1
        while os.path.exists(os.path.join(trash_files, unique_name)):
            if "." in file_name:
                parts = file_name.rsplit(".", 1)
                unique_name = f"{parts[0]}_{counter}.{parts[1]}"
            else:
                unique_name = f"{file_name}_{counter}"
            counter += 1
        
        dst = os.path.join(trash_files, unique_name)
        
        try:
            shutil.move(f, dst)
            add_to_trash(os.path.abspath(f), trash_path, unique_name, is_dir)
            
            if ".Trash-1000" in trash_path:
                info_file = os.path.join(trash_path, "info", unique_name + ".trashinfo")
                with open(info_file, "w") as fh:
                    fh.write(f"[Trash Info]\nPath={os.path.abspath(f)}\nDeletionDate=\n")
            
            print(f"Trashed: {file_name}")
        except Exception as e:
            print(f"Error: {e}")


def main():
    parser = argparse.ArgumentParser(prog="rtrash")
    subparsers = parser.add_subparsers(dest="command", help="Commands")
    
    subparsers.add_parser("list", help="List trashed files")
    subparsers.add_parser("ls", help="List trashed files (alias for list)")
    
    restore_parser = subparsers.add_parser("restore", help="Restore file from trash (opens fzf if no file specified)")
    restore_parser.add_argument("files", nargs="*", help="Files to restore")
    
    delete_parser = subparsers.add_parser("delete", help="Permanently delete from trash (opens fzf if no file specified)")
    delete_parser.add_argument("files", nargs="*", help="Files to delete")
    
    put_parser = subparsers.add_parser("put", help="Move file to trash")
    put_parser.add_argument("files", nargs="+", help="Files to trash")
    
    subparsers.add_parser("rm", help="Alias for delete")
    
    args = parser.parse_args()
    
    if args.command == "list" or args.command == "ls":
        cmd_list()
    elif args.command == "restore":
        cmd_restore(*args.files)
    elif args.command == "delete" or args.command == "rm":
        cmd_delete(*args.files)
    elif args.command == "put":
        cmd_put(*args.files)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
