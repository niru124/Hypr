#!/usr/bin/env bash

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

# --- Configuration Setup ---
CONFIG_DIR="$HOME/.config/linku"
CONFIG_FILE="$CONFIG_DIR/config"

# 1. Set Defaults
use_backup=true
explicit_dry_run=false
skip_confirm=false
MAX_COMMITS=50
GIT_MAX_COMMITS=50
BORG_MAX_COMMITS=10
BACKUP_ROOT="$HOME/backup"
MODE="sync"             # Default mode

# 2. Load Config File
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

# 3. Expand Tilde (~) in BACKUP_ROOT
BACKUP_ROOT="${BACKUP_ROOT/#\~/$HOME}"

# Paths & State
backup_repo_path=""
dest_base_prefix=""     
txt_file=""
target_src=""
target_dst=""
tracker_backend="git"   # Default to git unless $borg is specified

# --- Help ---
show_help() {
    echo -e "${CYAN}Linku - Hybrid Dotfile Sync & Backup (Git/Borg)${NC}"
    echo "Usage: linku [options] <command>[arguments]"
    echo ""
    echo "Commands:"
    echo "  linku files.txt          Sync files (Preview -> Confirm -> Sync)"
    echo "  linku restore files.txt  Mount backup history to restore old files"
    echo ""
    echo "Options:"
    echo "  -y, --no-dry             Skip preview (Immediate Sync)"
    echo "  -n, --dry-run            Preview ONLY"
    echo "  --no-backup              Disable backup"
    echo ""
    echo "Structure Definition (in .txt file):"
    echo "  \$borg [N]                <- Use BorgBackup (N = keep last N backups)"
    echo "  \$git [N]                 <- Use Git (N = keep last N commits)"
    echo "  @/path/to/base/          <- Defines the base of the destination drive"
    echo "  #exclude                 <- Global exclude patterns"
    echo "  src:dst                  <- Sync pair (Supports Wildcards like *.pdf)"
}

# --- Args ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-backup) use_backup=false; shift ;;
        --no-dry|-y) skip_confirm=true; shift ;;
        --dry-run|-n) explicit_dry_run=true; shift ;;
        --help|-h) show_help; exit 0 ;;
        restore) MODE="restore"; shift ;;
        *.txt) txt_file="$1"; shift ;;
        *)
            if [[ -z "$target_src" ]]; then target_src="$1"
            elif [[ -z "$target_dst" ]]; then target_dst="$1"; fi
            shift ;;
    esac
done

# --- Determine Backup Repo Path ---
if [[ -n "$txt_file" ]]; then
    base=$(basename "$txt_file")
    backup_repo_path="$BACKUP_ROOT/${base%.*}"
else
    backup_repo_path="$BACKUP_ROOT/manual"
fi

global_excludes=()

# --- Parse Config File Headers ---
parse_headers() {
    local file="$1"
    if [[ ! -f "$file" ]]; then return; fi
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        line=$(echo "$line" | xargs)
        if [[ "$line" =~ ^@(.+)$ ]]; then
            dest_base_prefix="${BASH_REMATCH[1]}"
            dest_base_prefix="${dest_base_prefix/#\~/$HOME}"
        elif [[ "$line" =~ ^#(.+)$ ]]; then
            local excludes_str="${BASH_REMATCH[1]}"
            IFS=',' read -r -a global_excludes <<< "$excludes_str"
            for i in "${!global_excludes[@]}"; do global_excludes[$i]=$(echo "${global_excludes[$i]}" | xargs); done
        elif [[ "$line" =~ ^\$git[[:space:]]*([[:digit:]]+)?$ ]]; then
            tracker_backend="git"
            if [[ -n "${BASH_REMATCH[1]}" ]]; then
                GIT_MAX_COMMITS="${BASH_REMATCH[1]}"
            fi
        elif [[ "$line" =~ ^\$borg[[:space:]]*([[:digit:]]+)?$ ]]; then
            tracker_backend="borg"
            if [[ -n "${BASH_REMATCH[1]}" ]]; then
                BORG_MAX_COMMITS="${BASH_REMATCH[1]}"
            fi
        fi
    done < "$file"
}

# --- Pretty Print ---
prettify_rsync() {
    local output="$1"
    if [[ -z "$output" ]]; then return; fi
    echo "$output" | while IFS= read -r line; do
        local code="${line%% *}"
        local file="${line#* }"
        if [[ "$line" == *deleting* ]]; then echo -e "  ${RED}[-]${NC} $file (del)"
        elif [[ "$code" == ">f+++++++" ]]; then echo -e "  ${GREEN}[+]${NC} $file (new)"
        elif [[ "$code" == *d* && "$code" != "."* ]]; then echo -e "  ${BLUE}[d]${NC} $file (dir)"
        elif [[ "$code" == ">f"* ]]; then echo -e "  ${YELLOW}[~]${NC} $file (mod)"
        fi
    done
}

# --- Git History Management ---
manage_git_history() {
    local repo="$1"
    if [[ ! -d "$repo/.git" || "$GIT_MAX_COMMITS" -le 0 ]]; then return; fi

    local count
    count=$(git -C "$repo" rev-list --count HEAD 2>/dev/null)

    if [[ "$count" -gt "$GIT_MAX_COMMITS" ]]; then
        echo -e "🧹 ${YELLOW}Git limit ($count/$MAX_COMMITS). Pruning old backups...${NC}"
        git -C "$repo" checkout --orphan temp_history_limit >/dev/null 2>&1
        git -C "$repo" add -A >/dev/null 2>&1
        git -C "$repo" commit -m "History Reset: Limit reached ($(date '+%Y-%m-%d'))" >/dev/null 2>&1
        git -C "$repo" branch -D master >/dev/null 2>&1
        git -C "$repo" branch -m master >/dev/null 2>&1
        git -C "$repo" gc --prune=now --aggressive >/dev/null 2>&1
        echo -e "✨ ${GREEN}History flattened to save space.${NC}"
    fi
}

# --- 1. Prepare Backup Repo ---
init_backup_repo() {
    if [[ "$use_backup" != true ]]; then return; fi
    mkdir -p "$backup_repo_path"

    if [[ "$tracker_backend" == "git" ]]; then
        if [[ ! -d "$backup_repo_path/.git" ]]; then
            git -C "$backup_repo_path" init -q
            git -C "$backup_repo_path" config user.email "backup@linku"
            git -C "$backup_repo_path" config user.name "Linku Backup"
        fi
    elif [[ "$tracker_backend" == "borg" ]]; then
        if ! command -v borg &> /dev/null; then
            echo -e "${RED}❌ BorgBackup is not installed! Please install 'borgbackup'.${NC}"
            exit 1
        fi
        local borg_repo_dir="$backup_repo_path/.borg_repo"
        if [[ ! -d "$borg_repo_dir" ]]; then
            borg init --encryption=none "$borg_repo_dir" >/dev/null 2>&1
        fi
    fi
}

# --- RESTORE MODE ---
# --- RESTORE MODE ---
handle_restore() {
    if [[ -z "$txt_file" ]]; then
        echo -e "${RED}❌ Please specify a file to restore from (e.g., linku restore files.txt)${NC}"
        exit 1
    fi

    parse_headers "$txt_file"

    if [[ "$tracker_backend" == "borg" ]]; then
        local borg_repo_dir="$backup_repo_path/.borg_repo"
        local mount_point="$backup_repo_path/RESTORE_MOUNT"
        
        if [[ ! -d "$borg_repo_dir" ]]; then
            echo -e "${RED}❌ No Borg repository found at $borg_repo_dir${NC}"
            exit 1
        fi
        
        mkdir -p "$mount_point"
        
        if mountpoint -q "$mount_point"; then
            echo -e "${YELLOW}⚠️  Already mounted. To unmount safely, run: borg umount $mount_point${NC}"
        else
            echo -e "🔄 Mounting Borg repository to: ${BLUE}$mount_point${NC}"
            
            # Try to mount, and catch the error if it fails (like missing FUSE)
            if ! borg mount "$borg_repo_dir" "$mount_point"; then
                echo -e "\n${RED}❌ Failed to mount the Borg repository.${NC}"
                echo -e "${YELLOW}It looks like FUSE support is missing on your system.${NC}"
                echo -e "Please install the required packages:"
                echo -e "  Arch Linux:    sudo pacman -S python-llfuse fuse3"
                echo -e "  Ubuntu/Debian: sudo apt install python3-llfuse fuse3"
                echo -e "  Fedora:        sudo dnf install python3-llfuse fuse3"
                rmdir "$mount_point" 2>/dev/null
                exit 1
            fi
            
            echo -e "✅ ${GREEN}Successfully mounted!${NC}"
            echo -e "📂 You can now open your file manager and browse:"
            echo -e "   ${BLUE}$mount_point${NC}"
            echo -e "   Inside, you will see folders for every backup date/time."
            echo -e "   Simply copy the older files you want back to your main drive."
            echo ""
            echo -e "🛑 ${YELLOW}Press [ENTER] to safely unmount and exit when you are done restoring.${NC}"
            read -r
            
            echo "Unmounting..."
            borg umount "$mount_point"
            rmdir "$mount_point" 2>/dev/null
            echo -e "✅ Unmounted safely."
        fi

    elif [[ "$tracker_backend" == "git" ]]; then
         echo -e "📂 Your Git repository is at: ${BLUE}$backup_repo_path${NC}"
         echo -e "To restore older files, open a terminal and run:"
         echo -e "  1. ${YELLOW}cd $backup_repo_path${NC}"
         echo -e "  2. ${YELLOW}git log --oneline${NC}  (Find the commit hash)"
         echo -e "  3. ${YELLOW}git checkout <hash> -- <filename>${NC}  (Restore the specific file)"
         echo -e "  4. Copy it back to your original location."
    fi
}

# --- 2. Update Mirror (Strict Structure Logic) ---
update_backup_mirror() {
    local src="$1"
    local dst="$2"
    shift 2
    local excludes=("$@")
    
    if [[ "$use_backup" != true ]]; then return; fi
    if [[ ! -e "$src" ]]; then return; fi

    local rsync_opts=(-a --delete --delete-excluded --exclude=".git" --exclude=".borg_repo" --exclude="RESTORE_MOUNT")
    for ex in "${excludes[@]}"; do rsync_opts+=(--exclude="$ex"); done

    local target_backup_path=""

    if [[ -n "$dest_base_prefix" && "$dst" == "$dest_base_prefix"* ]]; then
        local relative_path="${dst#$dest_base_prefix}"
        relative_path="${relative_path#/}"
        target_backup_path="$backup_repo_path/$relative_path"
    else
        target_backup_path="$backup_repo_path/$(basename "$src")"
    fi

    if [[ -d "$src" ]]; then
        mkdir -p "$target_backup_path"
        rsync "${rsync_opts[@]}" "$src/" "$target_backup_path/" >/dev/null 2>&1
    elif [[ -f "$src" ]]; then
        if [[ "$target_backup_path" == */ ]]; then
            mkdir -p "$target_backup_path"
            rsync "${rsync_opts[@]}" "$src" "$target_backup_path/" >/dev/null 2>&1
        else
            mkdir -p "$(dirname "$target_backup_path")"
            rsync "${rsync_opts[@]}" "$src" "$target_backup_path" >/dev/null 2>&1
        fi
    fi
}

# --- 3. Sync Node ---
sync_node() {
    local src="$1"
    local dst="$2"
    local is_dry="$3"
    shift 3
    local excludes=("$@")

    local rsync_opts=(-ai --delete --delete-excluded)
    for ex in "${excludes[@]}"; do rsync_opts+=(--exclude="$ex"); done

    if [[ "$is_dry" == true ]]; then
        rsync_opts+=(--dry-run)
        local output=""
        local header=""
        
        if [[ ! -e "$src" ]]; then echo -e "${RED}⚠️  Missing: $src${NC}"; return; fi

        if [[ -d "$src" ]]; then
            header="${BLUE}📁 Dir:${NC} $src → $dst"
            output=$(rsync "${rsync_opts[@]}" "$src"/ "$dst"/ 2>/dev/null)
        else
            header="${BLUE}📄 File:${NC} $src → $dst"
            if [[ "$dst" == */ ]]; then output=$(rsync "${rsync_opts[@]}" "$src" "$dst/" 2>/dev/null)
            elif [[ -d "$dst" ]]; then output=$(rsync "${rsync_opts[@]}" "$src" "$dst"/ 2>/dev/null)
            else output=$(rsync "${rsync_opts[@]}" "$src" "$dst" 2>/dev/null)
            fi
        fi

        if [[ -n "$output" ]]; then
            echo -e "$header"
            prettify_rsync "$output"
        fi
        return
    fi

    update_backup_mirror "$src" "$dst" "${excludes[@]}"

    rsync_opts=(-a --delete --delete-excluded)
    for ex in "${excludes[@]}"; do rsync_opts+=(--exclude="$ex"); done

    if [[ -d "$src" ]]; then
        mkdir -p "$dst"
        rsync "${rsync_opts[@]}" "$src"/ "$dst"/ >/dev/null
    elif [[ -f "$src" ]]; then
        if [[ "$dst" == */ ]]; then
            mkdir -p "$dst"
            rsync "${rsync_opts[@]}" "$src" "$dst/" >/dev/null
        elif [[ -d "$dst" ]]; then
            mkdir -p "$dst"
            rsync "${rsync_opts[@]}" "$src" "$dst"/ >/dev/null
        else
            mkdir -p "$(dirname "$dst")"
            rsync "${rsync_opts[@]}" "$src" "$dst" >/dev/null
        fi
    fi
}

# --- History Tracker Commit Logic ---
commit_backups() {
    if [[ "$use_backup" != true || ! -d "$backup_repo_path" ]]; then return; fi

    if [[ "$tracker_backend" == "git" ]]; then
        git -C "$backup_repo_path" add -A
        local has_changes=$(git -C "$backup_repo_path" status --porcelain)
        local commit_count=$(git -C "$backup_repo_path" rev-list --count HEAD 2>/dev/null || echo "0")

        if [[ -n "$has_changes" || "$commit_count" == "0" ]]; then
            local msg="Sync: $(date '+%Y-%m-%d %H:%M')"
            if [[ "$commit_count" == "0" ]]; then msg="Initial Backup"; fi
            
            if ! git -C "$backup_repo_path" diff --cached --quiet; then
                 git -C "$backup_repo_path" commit -q -m "$msg"
                 echo -e "📦 ${GREEN}Git backup committed:${NC} $backup_repo_path"
            fi
        fi
        manage_git_history "$backup_repo_path"

    elif [[ "$tracker_backend" == "borg" ]]; then
        local borg_repo_dir="$backup_repo_path/.borg_repo"
        
        # Only commit if the staging directory actually has files (skip if completely empty)
        if [[ -z "$(ls -A "$backup_repo_path" 2>/dev/null | grep -v -E '^\.borg_repo$|^RESTORE_MOUNT$')" ]]; then
             return
        fi

        echo -e "📦 ${CYAN}Compressing & Saving to Borg Vault (zstd)...${NC}"
        
        cd "$backup_repo_path" || return
        
        local snapshot_name="Sync-{now:%Y-%m-%d_%H-%M-%S}"
        borg create --compression auto,zstd \
            "$borg_repo_dir::$snapshot_name" \
            . --exclude './.borg_repo' --exclude './RESTORE_MOUNT' >/dev/null 2>&1
            
        if [[ "$BORG_MAX_COMMITS" -gt 0 ]]; then
            borg prune --keep-last "$BORG_MAX_COMMITS" "$borg_repo_dir" >/dev/null 2>&1
        fi
        
        echo -e "✨ ${GREEN}Borg snapshot verified & pruned successfully.${NC}"
        cd - >/dev/null || return
    fi
}

# --- Process File ---
process_txt_file() {
    local file="$1"
    local current_run_dry="$2"

    if [[ ! -f "$file" ]]; then echo "❌ File not found"; exit 1; fi

    # Headers are now parsed earlier globally by parse_headers()
    if [[ "$current_run_dry" == false ]]; then init_backup_repo; fi

    while IFS= read -r line || [[ -n "$line" ]]; do
        line=$(echo "$line" | xargs)
        
        if [[ -z "$line" || "$line" == \#* || "$line" == @* || "$line" == \$* ]]; then continue; fi

        local pair="$line"
        local path_part="${pair%%,*}"
        local excludes_part="${pair#*,}"
        if [[ "$path_part" == "$pair" ]]; then excludes_part=""; fi
        
        local src="${path_part%%:*}"
        local dst="${path_part#*:}"
        
        if [[ -z "$src" || -z "$dst" ]]; then continue; fi
        
        src="${src/#\~/$HOME}"
        dst="${dst/#\~/$HOME}"
        
        if [[ -n "$dest_base_prefix" && ! "$dst" == /* ]]; then
            dst="$dest_base_prefix$dst"
        fi

        IFS=',' read -r -a excludes <<< "$excludes_part"
        for i in "${!excludes[@]}"; do excludes[$i]=$(echo "${excludes[$i]}" | xargs); done
        local all_excludes=("${global_excludes[@]}" "${excludes[@]}")
        
        if [[ "$src" == *\** || "$src" == *\?* || "$src" == *\[* ]]; then
            local expanded_srcs=()
            while IFS= read -r match; do
                expanded_srcs+=("$match")
            done < <(compgen -G "$src" 2>/dev/null)

            if [[ ${#expanded_srcs[@]} -eq 0 ]]; then
                echo -e "⚠️  ${YELLOW}No matches for:${NC} $src"
                continue
            fi

            for expanded_src in "${expanded_srcs[@]}"; do
                local base_name=$(basename "$expanded_src")
                local expanded_dst=""

                if [[ "$dst" == *\** ]]; then expanded_dst="$(dirname "$dst")/$base_name"
                elif [[ "$dst" == */ ]]; then expanded_dst="${dst}${base_name}"
                else expanded_dst="${dst}/${base_name}"
                fi

                sync_node "$expanded_src" "$expanded_dst" "$current_run_dry" "${all_excludes[@]}"
            done
        else
            sync_node "$src" "$dst" "$current_run_dry" "${all_excludes[@]}"
        fi

    done < "$file"

    if [[ "$current_run_dry" == false ]]; then
        commit_backups
    fi
}

# --- Main ---
main() {
    if [[ ! -d "$CONFIG_DIR" ]]; then mkdir -p "$CONFIG_DIR"; fi

    # Check if user requested RESTORE MODE
    if [[ "$MODE" == "restore" ]]; then
        handle_restore
        exit 0
    fi

    # Initialize Headers early so preview knows which tracker we use
    if [[ -n "$txt_file" ]]; then
        parse_headers "$txt_file"
    fi

    run_batch() {
        local is_dry="$1"
        if [[ -n "$txt_file" ]]; then
            process_txt_file "$txt_file" "$is_dry"
        elif [[ -n "$target_src" && -n "$target_dst" ]]; then
            if [[ "$is_dry" == false ]]; then init_backup_repo; fi
            local src="${target_src/#\~/$HOME}"
            local dst="${target_dst/#\~/$HOME}"
            sync_node "$src" "$dst" "$is_dry" "${global_excludes[@]}"
            if [[ "$is_dry" == false ]]; then commit_backups; fi
        else
            show_help; exit 1
        fi
    }

    if [[ "$explicit_dry_run" == true ]]; then
        echo -e "${CYAN}🔍 PREVIEW (Dry Run)${NC}"
        run_batch true
        echo -e "\n${BLUE}ℹ️  No changes made.${NC}"; exit 0
    fi

    if [[ "$skip_confirm" == true ]]; then
        run_batch false
        echo -e "${GREEN}✅ Done.${NC}"; exit 0
    fi

    echo -e "${CYAN}🔍 ANALYZING...${NC}"
    run_batch true

    echo ""
    echo -e "${YELLOW}⚠️  Review changes.${NC}"
    if [[ "$use_backup" == true ]]; then
        if [[ "$tracker_backend" == "borg" ]]; then
            echo -e "   Tracker:     ${BLUE}BorgBackup (Zstd Chunk Deduplication)${NC}"
        else
            echo -e "   Tracker:     ${BLUE}Git (Standard History)${NC}"
        fi
        
        echo -e "   Backup Repo: ${BLUE}$backup_repo_path${NC}"
        
        if [[ -n "$dest_base_prefix" ]]; then
             echo -e "   Structure:   ${BLUE}Mapped by destination${NC} (Base: $dest_base_prefix)"
        else
             echo -e "   Structure:   ${BLUE}Flat${NC} (Source Name)"
        fi
    fi
    
    read -p "   Proceed? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then echo -e "${RED}❌ Cancelled.${NC}"; exit 0; fi

    echo -e "${GREEN}🚀 Syncing...${NC}"
    run_batch false
    echo -e "${GREEN}✅ Success.${NC}"
}

main "$@"
