#!/usr/bin/env bash

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Default settings
use_backup=true
explicit_dry_run=false  # User passed -n (Show preview and exit)
skip_confirm=false      # User passed -y (Skip preview and confirm)

# Paths
backup_root="$HOME/backups"
backup_sub_name=""      
txt_file=""
target_src=""
target_dst=""

show_help() {
    echo -e "${CYAN}Linku - Safe Dotfile Syncer with Git Backups${NC}"
    echo "Usage: linku [options] <source> [destination]"
    echo ""
    echo "Modes:"
    echo "  linku files.txt        Read pairs from file (src:dst, exclude...)"
    echo "                         (Default: Preview changes → Ask to confirm → Sync)"
    echo "  linku src/ dst/        Sync a single directory or file"
    echo ""
    echo "Options:"
    echo "  -y, --no-dry           Skip preview and confirmation (Immediate Sync)"
    echo "  -n, --dry-run          Show preview ONLY (No changes, no prompt)"
    echo "  --no-backup            Disable backup creation"
    echo "  -h, --help             Show this help message"
    echo ""
    echo "Backup System:"
    echo "  Backups are stored in: ${BLUE}$HOME/backup/<name>/${NC}"
    echo "  - If running 'linku nvim.txt', backups go to '~/backup/nvim/'"
    echo "  - Each backup folder is an independent Git repository."
    echo "  - You can cd into a backup folder and use 'git log' to see history."
}

# --- Argument Parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-backup)
            use_backup=false
            shift
            ;;
        --no-dry|-y)
            skip_confirm=true
            shift
            ;;
        --dry-run|-n)
            explicit_dry_run=true
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *.txt)
            txt_file="$1"
            shift
            ;;
        *)
            if [[ -z "$target_src" ]]; then
                target_src="$1"
            elif [[ -z "$target_dst" ]]; then
                target_dst="$1"
            fi
            shift
            ;;
    esac
done

# --- Determine Backup Sub-Directory ---
if [[ -n "$txt_file" ]]; then
    # e.g., "nvim.txt" -> "nvim"
    filename=$(basename "$txt_file")
    backup_sub_name="${filename%.*}"
else
    backup_sub_name="manual"
fi

current_backup_path="$backup_root/$backup_sub_name"
global_excludes=()

# --- Helper: Pretty Print Rsync Itemized Output ---
prettify_rsync() {
    local raw_output="$1"
    if [[ -z "$raw_output" ]]; then return; fi

    echo "$raw_output" | while IFS= read -r line; do
        local code="${line%% *}"
        local file="${line#* }"
        
        # Rsync itemize format: YXcstpoguax
        if [[ "$line" == *deleting* ]]; then
            echo -e "  ${RED}[-]${NC} $file (delete)"
        elif [[ "$code" == ">f+++++++" ]]; then
            echo -e "  ${GREEN}[+]${NC} $file (new)"
        elif [[ "$code" == *d* && "$code" != "."* ]]; then
            echo -e "  ${BLUE}[d]${NC} $file (directory)"
        elif [[ "$code" == ">f"* ]]; then
            echo -e "  ${YELLOW}[~]${NC} $file (modified)"
        elif [[ "$code" == "cL"* ]]; then
            echo -e "  ${CYAN}[@]${NC} $file (link created)"
        fi
    done
}

# --- Core Sync Function ---
sync_node() {
    local src="$1"
    local dst="$2"
    local is_dry="$3"
    shift 3
    local excludes=("$@")

    # Base rsync options:
    # -a: archive (recursive, preserve times/perms)
    # -i: itemize changes (crucial for pretty output)
    local rsync_opts=(-ai --delete --delete-excluded)

    for ex in "${excludes[@]}"; do
        rsync_opts+=(--exclude="$ex")
    done

    # -----------------------
    # 1. DRY RUN (PREVIEW)
    # -----------------------
    if [[ "$is_dry" == true ]]; then
        rsync_opts+=(--dry-run)
        local output=""
        local header=""

        # Check source existence
        if [[ ! -e "$src" ]]; then
            echo -e "${RED}⚠️  Source missing:${NC} $src"
            return
        fi

        if [[ -d "$src" ]]; then
            header="${BLUE}📁 Dir:${NC} $src → $dst"
            output=$(rsync "${rsync_opts[@]}" "$src"/ "$dst"/ 2>/dev/null)
        else
            header="${BLUE}📄 File:${NC} $src → $dst"
            if [[ -d "$dst" ]]; then
                output=$(rsync "${rsync_opts[@]}" "$src" "$dst"/ 2>/dev/null)
            else
                output=$(rsync "${rsync_opts[@]}" "$src" "$dst" 2>/dev/null)
            fi
        fi

        # If rsync produced output, it means changes are detected
        if [[ -n "$output" ]]; then
            echo -e "$header"
            prettify_rsync "$output"
        fi
        return
    fi

    # -----------------------
    # 2. REAL EXECUTION
    # -----------------------
    
    # A. Setup Independent Git Backup
    if [[ "$use_backup" == true ]]; then
        mkdir -p "$current_backup_path"
        
        # Initialize Git ONLY if not already a repo
        if [[ ! -d "$current_backup_path/.git" ]]; then
            git -C "$current_backup_path" init -q
            git -C "$current_backup_path" config user.email "backup@linku"
            git -C "$current_backup_path" config user.name "Linku Backup"
            git -C "$current_backup_path" add -A
            git -C "$current_backup_path" commit -q -m "Root Init" --allow-empty
        fi

        # Update rsync options for backup
        # Remove -i (too verbose for real run), add -v, add --backup
        rsync_opts=(-av --delete --delete-excluded --backup --backup-dir="$current_backup_path")
    else
        rsync_opts=(-av --delete --delete-excluded)
    fi

    for ex in "${excludes[@]}"; do
        rsync_opts+=(--exclude="$ex")
    done

    # B. Execute Rsync
    if [[ -d "$src" ]]; then
        mkdir -p "$dst"
        rsync "${rsync_opts[@]}" "$src"/ "$dst"/ >/dev/null
    elif [[ -f "$src" ]]; then
        if [[ -d "$dst" ]]; then
            mkdir -p "$dst"
            rsync "${rsync_opts[@]}" "$src" "$dst"/ >/dev/null
        else
            mkdir -p "$(dirname "$dst")"
            rsync "${rsync_opts[@]}" "$src" "$dst" >/dev/null
        fi
    fi

    # C. Commit Backup Changes to Git
    if [[ "$use_backup" == true ]]; then
        git -C "$current_backup_path" add -A
        # Check if git status is clean
        if [[ -n "$(git -C "$current_backup_path" status --porcelain)" ]]; then
            local msg="Backup: $(date '+%Y-%m-%d %H:%M:%S')"
            git -C "$current_backup_path" commit -q -m "$msg"
        fi
    fi
}

# --- File Processor ---
process_txt_file() {
    local file="$1"
    local current_run_dry="$2"

    if [[ ! -f "$file" ]]; then
        echo -e "${RED}❌ File not found: $file${NC}"
        exit 1
    fi

    # Read global excludes from first line
    if IFS= read -r first_line < "$file"; then
        if [[ "$first_line" =~ ^#(.+)$ ]]; then
            local excludes_str="${BASH_REMATCH[1]}"
            IFS=',' read -r -a global_excludes <<< "$excludes_str"
            for i in "${!global_excludes[@]}"; do
                global_excludes[$i]=$(echo "${global_excludes[$i]}" | xargs)
            done
        fi
    fi

    # Process pairs
    local content=$(sed '1d' "$file" | tr '\n' ' ' | tr -s ' ')
    
    for pair in $content; do
        local path_part="${pair%%,*}"
        local excludes_part="${pair#*,}"

        if [[ "$path_part" == "$pair" ]]; then excludes_part=""; fi

        local src="${path_part%%:*}"
        local dst="${path_part#*:}"

        if [[ -z "$src" || -z "$dst" ]]; then continue; fi

        src="${src/#\~/$HOME}"
        dst="${dst/#\~/$HOME}"

        IFS=',' read -r -a excludes <<< "$excludes_part"
        for i in "${!excludes[@]}"; do
            excludes[$i]=$(echo "${excludes[$i]}" | xargs)
        done

        local all_excludes=("${global_excludes[@]}" "${excludes[@]}")
        sync_node "$src" "$dst" "$current_run_dry" "${all_excludes[@]}"
    done
}

# --- Main Logic Flow ---
main() {
    # Wrapper to switch between file mode and argument mode
    run_batch() {
        local is_dry="$1"
        if [[ -n "$txt_file" ]]; then
            process_txt_file "$txt_file" "$is_dry"
        elif [[ -n "$target_src" && -n "$target_dst" ]]; then
            local src="${target_src/#\~/$HOME}"
            local dst="${target_dst/#\~/$HOME}"
            sync_node "$src" "$dst" "$is_dry" "${global_excludes[@]}"
        else
            show_help
            exit 1
        fi
    }

    # CASE 1: Explicit Dry Run (-n)
    if [[ "$explicit_dry_run" == true ]]; then
        echo -e "${CYAN}🔍 DRY RUN PREVIEW ONLY${NC}"
        run_batch true
        echo ""
        echo -e "${BLUE}ℹ️  No changes made (-n used).${NC}"
        exit 0
    fi

    # CASE 2: Explicit No-Dry (-y)
    if [[ "$skip_confirm" == true ]]; then
        run_batch false
        echo -e "${GREEN}✅ Sync complete.${NC}"
        exit 0
    fi

    # CASE 3: Standard (Preview -> Ask -> Sync)
    echo -e "${CYAN}🔍 ANALYZING CHANGES...${NC}"
    run_batch true # Run with dry_run=true

    echo ""
    echo -e "${YELLOW}⚠️  Review changes above.${NC}"
    if [[ "$use_backup" == true ]]; then
        echo -e "   Backup Location: ${BLUE}$current_backup_path${NC} (Git initialized)"
    fi
    
    read -p "   Proceed with sync? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${RED}❌ Cancelled.${NC}"
        exit 0
    fi

    echo -e "${GREEN}🚀 Syncing...${NC}"
    run_batch false # Run with dry_run=false
    echo -e "${GREEN}✅ Done.${NC}"
}

main "$@"
